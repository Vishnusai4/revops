# RevOps Landing Page Environment Variables
# Copy this file to .env.local and fill in the values

# ===== REQUIRED =====
# Google Calendar booking link (primary CTA)
NEXT_PUBLIC_CALENDAR_URL=https://calendar.app.google/RFAVCBpXK7AWYxt67

# Fallback contact email
CONTACT_EMAIL=vishnu@teravictus.com

# ===== REQUIRED - Resend Email =====
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx

# ===== OPTIONAL - Analytics =====
# Google Analytics ID (e.g., G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# ===== OPTIONAL - HubSpot Integration =====
# HubSpot Portal ID and Form ID for contact form submissions
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_ID=

# ===== OPTIONAL - Webhook Integrations =====
# Pipedream webhook URL for workflow automation
PIPEDREAM_WEBHOOK_URL=

# Slack webhook URL for notifications
SLACK_WEBHOOK_URL=

# ===== OPTIONAL - Error Tracking =====
# Sentry DSN for error monitoring
SENTRY_DSN=
